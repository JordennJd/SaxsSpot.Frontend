# SaxsSpot Frontend Environment Configuration
# Copy this file to .env and fill in your values

# Development/Production Mode
NODE_ENV=development

# API Configuration
# Nanosystem API URL
VITE_NANOSYSTEM_API_URL=http://localhost:5062/api

# Calculation API URL  
VITE_CALCULATION_API_URL=http://localhost:5067/api

# Job Management API URL
VITE_JOB_API_URL=http://localhost:8080

# Job API Authentication Token (required for job management features)
# Replace with your actual JWT token
VITE_JOB_AUTH_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTUxNjIzOTAyMn0.KMUFsIDTnFmyG3nMiGM6H9FNFUROf3wh7SmqJp-QV30

